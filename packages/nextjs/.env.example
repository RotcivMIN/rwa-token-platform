# ============================================================
# Vercel Environment Variables
# Copy Key/Value pairs into: Vercel Dashboard > Settings > Environment Variables
# ============================================================
# For local dev: copy this file to .env.local and fill in values

# [Required for Sepolia RPC] Infura API key — get yours at https://app.infura.io
# If not set, falls back to Alchemy automatically
NEXT_PUBLIC_INFURA_API_KEY=

# [Optional] Alchemy API key — default scaffold-eth key used if blank
NEXT_PUBLIC_ALCHEMY_API_KEY=

# [Optional] WalletConnect project ID — default ID used if blank
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
